# MintStack Finance Portal - Backend Production Environment
# Copy this file to .env.production and fill in the values
# IMPORTANT: Use strong, unique passwords in production!

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Generate strong password: openssl rand -base64 32
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mintstack_finance
POSTGRES_USER=mintstack_admin
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_HERE

# ===========================================
# KEYCLOAK
# ===========================================
KEYCLOAK_URL=https://auth.yourdomain.com
KEYCLOAK_REALM=mintstack-finance
KEYCLOAK_CLIENT_ID=finance-backend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_GET_FROM_KEYCLOAK_ADMIN

# ===========================================
# JWT / Security
# ===========================================
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_STRING
JWT_EXPIRATION_MS=86400000

# ===========================================
# CORS
# ===========================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# EMAIL (SMTP)
# ===========================================
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM=MintStack Finance <noreply@yourdomain.com>

# ===========================================
# API KEYS (Optional - Set via Settings UI)
# ===========================================
# These are optional - users can add their own via Settings page
# ALPHA_VANTAGE_API_KEY=
# YAHOO_FINANCE_API_KEY=
# FINNHUB_API_KEY=

# ===========================================
# REDIS (Optional - for caching)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/mintstack/application.log

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000
