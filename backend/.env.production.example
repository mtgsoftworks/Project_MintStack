# ===========================================
# MintStack Finance Portal - Backend Production Environment
# ===========================================
# These values are passed as environment variables to the Spring Boot container.
# For Docker Compose production, secrets are preferred (see docker-compose.prod.yml).
# ===========================================

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mintstack_finance
SPRING_DATASOURCE_USERNAME=mintstack
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=CHANGE_ME

SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://keycloak:8080/realms/mintstack-finance
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/realms/mintstack-finance/protocol/openid-connect/certs

ALPHA_VANTAGE_API_KEY=CHANGE_ME
FINNHUB_API_KEY=CHANGE_ME

OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=finance-portal

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@mintstack.com
