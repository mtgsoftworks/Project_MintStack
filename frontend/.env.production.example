# ===========================================
# MintStack Finance Portal - Frontend Production Environment
# ===========================================
# Copy this file to .env.production and update the values
# These variables are embedded at BUILD TIME by Vite
# ===========================================

VITE_API_URL=/api/v1
VITE_KEYCLOAK_URL=https://your-domain.com/auth
VITE_KEYCLOAK_REALM=mintstack-finance
VITE_KEYCLOAK_CLIENT_ID=finance-frontend
VITE_WS_URL=wss://your-domain.com/ws
VITE_SENTRY_DSN=
