    INSTRUMENTS ||--o{ PORTFOLIO_ITEMS : "varlik referansi"
    INSTRUMENTS ||--o{ PORTFOLIO_TRANSACTIONS : "islem enstrumani"
    USERS ||--o{ WATCHLISTS : "takip listesi olusturur"
    WATCHLISTS ||--o{ WATCHLIST_ITEMS : "madde icerir"
    INSTRUMENTS ||--o{ WATCHLIST_ITEMS : "izlenir"
    USERS ||--o{ PRICE_ALERTS : "alarm tanimlar"
    INSTRUMENTS ||--o{ PRICE_ALERTS : "alarm konusu olur"
    USERS ||--o{ USER_NOTIFICATIONS : "bildirim alir"
    USERS ||--o{ USER_API_CONFIGS : "api ayari yapar"
    USERS ||--o{ USER_DATA_PREFERENCES : "veri kaynagi secer"
    NEWS_CATEGORIES ||--o{ NEWS : "haber kategorisi"
