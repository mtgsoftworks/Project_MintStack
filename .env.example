# ===========================================
# MintStack Finance Portal - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# Generate secrets with: openssl rand -base64 32
# ===========================================

# --- PostgreSQL ---
# Database configuration for all services
POSTGRES_DB=mintstack_finance
POSTGRES_USER=mintstack
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- Redis ---
# Generate: openssl rand -base64 24
REDIS_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
# Generate: openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=<GENERATE_WITH_openssl_rand_base64_32>
# Client secret for finance-backend service (used in realm-export.json)
KEYCLOAK_FINANCE_BACKEND_SECRET=<GENERATE_WITH_openssl_rand_base64_32>
# Initial user passwords (change on first login)
KEYCLOAK_ADMIN_USER_PASSWORD=<GENERATE_STRONG_PASSWORD>
KEYCLOAK_TEST_USER_PASSWORD=<GENERATE_STRONG_PASSWORD>

# --- OpenLDAP ---
LDAP_ORGANISATION=MintStack
LDAP_DOMAIN=mintstack.local
# Generate: openssl rand -base64 24
LDAP_ADMIN_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>
# LDAP bind credential for Keycloak integration (same as LDAP_ADMIN_PASSWORD)
LDAP_BIND_CREDENTIAL=${LDAP_ADMIN_PASSWORD}

# --- Kafka (SASL Authentication) ---
KAFKA_BROKER_ID=1
# Generate: openssl rand -base64 24
KAFKA_SASL_USER=kafka
KAFKA_SASL_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- OpenSearch ---
# Must be at least 8 characters with uppercase, lowercase, numbers, and special chars
# Generate a strong password manually or use: openssl rand -base64 16
OPENSEARCH_INITIAL_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD_MIN_8_CHARS>

# --- Grafana ---
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=dev

# --- External APIs ---
# Get your API key at: https://www.alphavantage.co/support/#api-key
# 'demo' key has limited requests - replace with your own key
ALPHA_VANTAGE_API_KEY=<GET_YOUR_API_KEY_FROM_alphavantage.co>
# Get your API key at: https://finnhub.io/register
FINNHUB_API_KEY=<GET_YOUR_API_KEY_FROM_finnhub.io>

# --- Vite Frontend ---
VITE_API_URL=http://localhost:18080/api/v1
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=mintstack-finance
VITE_KEYCLOAK_CLIENT_ID=finance-frontend
VITE_WS_URL=http://localhost:18080/ws

# --- Production Only (used by docker-compose.prod.yml) ---
KC_HOSTNAME=localhost
