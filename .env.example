# ===========================================
# MintStack Finance Portal - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# Generate secrets with: openssl rand -base64 32
# ===========================================

# --- PostgreSQL ---
# Database configuration for all services
POSTGRES_DB=mintstack_finance
POSTGRES_USER=mintstack
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- Redis ---
# Generate: openssl rand -base64 24
REDIS_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
# Generate: openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=<GENERATE_WITH_openssl_rand_base64_32>
# Client secret for finance-backend service (used in realm-export.json)
KEYCLOAK_FINANCE_BACKEND_SECRET=<GENERATE_WITH_openssl_rand_base64_32>
# Initial user passwords (change on first login)
KEYCLOAK_ADMIN_USER_PASSWORD=<GENERATE_STRONG_PASSWORD>
KEYCLOAK_TEST_USER_PASSWORD=<GENERATE_STRONG_PASSWORD>

# --- OpenLDAP ---
LDAP_ORGANISATION=MintStack
LDAP_DOMAIN=mintstack.local
# Generate: openssl rand -base64 24
LDAP_ADMIN_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>
# LDAP bind credential for Keycloak integration (same as LDAP_ADMIN_PASSWORD)
LDAP_BIND_CREDENTIAL=${LDAP_ADMIN_PASSWORD}

# --- Kafka (SASL Authentication) ---
# KRaft cluster ID (stable across restarts)
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
# Generate: openssl rand -base64 24
KAFKA_SASL_USER=kafka
KAFKA_SASL_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- OpenSearch ---
# Must be at least 8 characters with uppercase, lowercase, numbers, and special chars
# Generate a strong password manually or use: openssl rand -base64 16
OPENSEARCH_INITIAL_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD_MIN_8_CHARS>

# --- Grafana ---
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=<GENERATE_WITH_openssl_rand_base64_24>

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=dev
APP_MESSAGING_ENABLED=true
APP_MARKET_DATA_CONSUMER_ENABLED=true
APP_MARKET_DATA_CONSUMER_GROUP_ID=market-data-consumer
APP_MARKET_DATA_CONSUMER_DLT_ENABLED=true
APP_MARKET_DATA_CONSUMER_RETRY_MAX_ATTEMPTS=3
APP_MARKET_DATA_CONSUMER_RETRY_BACKOFF_MS=1000

# Scheduler cadence (cron)
APP_SCHEDULER_TCMB_RATES_CRON=0 30 10,16 * * MON-FRI
APP_SCHEDULER_STOCK_PRICES_CRON=*/20 * * * * *
APP_SCHEDULER_BOND_PRICES_CRON=0 */2 * * * *
APP_SCHEDULER_FUND_PRICES_CRON=0 */3 * * * *
APP_SCHEDULER_VIOP_PRICES_CRON=*/30 * * * * *
APP_SCHEDULER_FOREX_RATES_CRON=0 */5 * * * MON-FRI
APP_SCHEDULER_NEWS_FETCH_CRON=0 */15 * * * *
APP_SCHEDULER_CLEANUP_CRON=0 0 2 * * *
APP_SCHEDULER_INSTRUMENT_BATCH_SIZE=5

# Rate limiting (requests/minute)
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_ANONYMOUS_REQUESTS_PER_MINUTE=100
APP_RATE_LIMIT_AUTHENTICATED_REQUESTS_PER_MINUTE=200
APP_RATE_LIMIT_ADMIN_REQUESTS_PER_MINUTE=500

# News ingestion
APP_NEWS_FETCH_WHEN_SIMULATION_ENABLED=true
APP_NEWS_SIMULATION_ENABLED=false
APP_NEWS_MAX_ITEMS_PER_FEED=10
APP_NEWS_CONNECT_TIMEOUT_MS=10000
APP_NEWS_READ_TIMEOUT_MS=10000
APP_NEWS_LLM_ENABLED=false
APP_NEWS_LLM_BASE_URL=
APP_NEWS_LLM_ENDPOINT=/v1/chat/completions
APP_NEWS_LLM_MODEL=gpt-4.1-mini
APP_NEWS_LLM_API_KEY=
APP_NEWS_LLM_API_KEY_HEADER=Authorization
APP_NEWS_LLM_API_KEY_PREFIX=Bearer
APP_NEWS_LLM_TIMEOUT_MS=15000
APP_NEWS_LLM_MAX_INPUT_CHARS=4000
APP_NEWS_LLM_TEMPERATURE=0.2
# GitHub Models quick start (optional):
# APP_NEWS_LLM_ENABLED=true
# APP_NEWS_LLM_BASE_URL=https://models.github.ai/inference
# APP_NEWS_LLM_ENDPOINT=/chat/completions
# APP_NEWS_LLM_MODEL=openai/gpt-5
# APP_NEWS_LLM_API_KEY=<YOUR_GITHUB_TOKEN>

# --- Cache TTLs (seconds) ---
APP_CACHE_CURRENCY_RATES_TTL=300
APP_CACHE_INSTRUMENTS_TTL=120
APP_CACHE_STOCK_PRICES_TTL=60
APP_CACHE_HISTORICAL_DATA_TTL=300
APP_CACHE_INDEX_VALUES_TTL=300
APP_CACHE_NEWS_TTL=600
APP_CACHE_PORTFOLIO_TTL=120
APP_CACHE_USERS_TTL=600
APP_CACHE_DEFAULT_TTL=300
APP_CACHE_SIMULATION_CONFIG_LEGACY_TTL=600
APP_CACHE_SIMULATION_STOCK_TTL=300
APP_CACHE_SIMULATION_CURRENCY_TTL=300
APP_CACHE_SIMULATION_INDEX_TTL=300
APP_CACHE_SIMULATION_CONFIG_TTL=600

# --- External APIs ---
# Get your API key at: https://www.alphavantage.co/support/#api-key
# 'demo' key has limited requests - replace with your own key
ALPHA_VANTAGE_API_KEY=<GET_YOUR_API_KEY_FROM_alphavantage.co>
# Get your API key at: https://finnhub.io/register
FINNHUB_API_KEY=<GET_YOUR_API_KEY_FROM_finnhub.io>
APP_EXTERNAL_API_TEFAS_ENABLED=true
APP_EXTERNAL_API_TEFAS_TIMEOUT=60000
APP_EXTERNAL_API_TEFAS_FUND_LIST_ENDPOINT=/fonGnlBlgSiraliGetir
APP_EXTERNAL_API_TEFAS_DEFAULT_FUND_KINDS=YAT,BYF
APP_EXTERNAL_API_TEFAS_FUND_CODES=
APP_EXTERNAL_API_FINTABLES_ENABLED=false
FINTABLES_BASE_URL=https://api.fintables.com
FINTABLES_API_KEY=
APP_EXTERNAL_API_FINTABLES_TIMEOUT=15000

# Alert webhook security
APP_ALERT_WEBHOOK_ENABLED=true
APP_ALERT_WEBHOOK_REQUIRE_SIGNATURE=false
APP_ALERT_WEBHOOK_SECRET=
APP_ALERT_WEBHOOK_SIGNATURE_HEADER=X-Alert-Signature
APP_ALERT_WEBHOOK_SIGNATURE_PREFIX=sha256=
APP_ALERT_WEBHOOK_TRUST_FORWARDED_FOR=false
APP_ALERT_WEBHOOK_TRUSTED_PROXY_CIDRS=
APP_ALERT_WEBHOOK_ALLOWED_CIDRS=

# --- Vite Frontend ---
VITE_API_URL=http://localhost:8088/api/v1
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=mintstack-finance
VITE_KEYCLOAK_CLIENT_ID=finance-frontend
VITE_WS_URL=http://localhost:8088/ws

# --- Production Only (used by docker-compose.prod.yml) ---
KC_HOSTNAME=localhost
