# ===========================================
# MintStack Finance Portal - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ===========================================

# --- PostgreSQL ---
POSTGRES_DB=mintstack_finance
POSTGRES_USER=mintstack
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password

# --- OpenLDAP ---
LDAP_ORGANISATION=MintStack
LDAP_DOMAIN=mintstack.local
LDAP_ADMIN_PASSWORD=CHANGE_ME_ldap_admin_password

# --- Kafka ---
KAFKA_BROKER_ID=1

# --- OpenSearch ---
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME_OpenSearch_1!

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=dev

# --- External APIs ---
ALPHA_VANTAGE_API_KEY=demo
FINNHUB_API_KEY=

# --- Frontend (Keycloak) ---
REACT_APP_KEYCLOAK_URL=http://localhost:8180
REACT_APP_KEYCLOAK_REALM=mintstack-finance
REACT_APP_KEYCLOAK_CLIENT_ID=finance-frontend

# --- Vite Frontend ---
VITE_API_URL=http://localhost:18080/api/v1
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=mintstack-finance
VITE_KEYCLOAK_CLIENT_ID=finance-frontend
VITE_WS_URL=http://localhost:18080/ws

# --- Production Only (used by docker-compose.prod.yml) ---
KC_HOSTNAME=localhost
